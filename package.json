{
  "name": "openkb-mesh-internet",
  "version": "0.1.0",
  "description": "A learn-by-doing Meshtastic console: connect over USB, watch the mesh, understand power and range.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "prestart": "npm run stop --silent 2>/dev/null || true",
    "start": "npm run build && electron dist-electron/main.js",
    "stop": "pkill -f 'electron dist-electron/main.js' 2>/dev/null; sleep 0.3; echo 'Stopped'",
    "restart": "npm run stop && npm start",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@meshtastic/protobufs": "^2.7.18",
    "better-sqlite3": "^12.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
